# Copy to apps/me/.env.local and apps/admin/.env.local (Next convention).
# Never commit real keys. Supabase values from dashboard or MCP (get_project_url / get_publishable_keys).

# Production API (no path prefix — routes are /qr, /claim, /profiles, … on the host root).
NEXT_PUBLIC_API_URL=https://api.bearhacks.com

# Local API only if you run FastAPI on your machine:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: debug | info | warn | error | silent (default dev=debug, prod=info)
# NEXT_PUBLIC_LOG_LEVEL=info
